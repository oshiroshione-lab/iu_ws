# ============================================================
# このファイルは「見本」です。中身は空のままGitに上げてOK。
# 実際の鍵は .env.local（Gitに上がらない）にコピーして書きます。
#   コピー手順: このファイルを複製して .env.local にリネーム → 値を埋める
# ============================================================

# --- OpenAI（必須） ---
# OpenAI のAPIキー。https://platform.openai.com/api-keys で発行。
# このキー1つでテキスト・画像・（将来の）議事録の文字起こしが使えます。
OPENAI_API_KEY=

# 用語の説明文・関連ワードを作るテキストモデル（安い順: gpt-5.4-nano < gpt-5.4-mini < gpt-5.4 < gpt-5.5）
OPENAI_TEXT_MODEL=gpt-5.4-mini
# イメージイラストを作る画像モデル
OPENAI_IMAGE_MODEL=gpt-image-2

# --- 仮のログイン（DB・本認証が決まるまでの暫定） ---
# 入れる3人の名前をカンマ区切りで。空にすると「どんな名前でも入れる」開発モードになります。
ALLOWED_MEMBERS=
# 共通の合言葉（パスワード代わり）。空にすると合言葉なしで入れます。
ACCESS_CODE=
